{
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/identity/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/identity" }
        ]
      },
      "iam-route": {
        "ClusterId": "iam-cluster",
        "Match": {
          "Path": "/api/iam/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/iam" }
        ]
      },
      "administration-route": {
        "ClusterId": "administration-cluster",
        "Match": {
          "Path": "/api/administration/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/administration" }
        ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://identity-api"
          }
        }
      },
      "iam-cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://iam-api"
          }
        }
      },
      "administration-cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://administration-api"
          }
        }
      }
    }
  }
}