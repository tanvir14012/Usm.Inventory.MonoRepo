POSTGRES_USER=usm_admin
POSTGRES_PASSWORD=usm_admin
POSTGRES_DB=usm_inventory
POSTGRES_PORT=5432
POSTGRES_CONNECTION_STRING=Host=localhost;Port=5432;Database=usm_inventory;Username=usm_admin;Password=usm_admin

RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_HOST=localhost
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

REDIS_PORT=6379
REDIS_CONNECTION_STRING=localhost:6379

Caching__Redis__ConnectionString=localhost:6379
Caching__Redis__InstanceName=usm-cache
Caching__Redis__KeyPrefix=usm
Caching__Redis__DefaultAbsoluteExpirationSeconds=300
Caching__Redis__DefaultSlidingExpirationSeconds=120
Caching__Redis__EnableCompression=true
Caching__Redis__CompressionThresholdBytes=1024
Caching__Redis__ConnectRetry=3
Caching__Redis__ConnectTimeoutMilliseconds=5000
Caching__Redis__SyncTimeoutMilliseconds=5000
Caching__Redis__UseCamelCaseJson=true

Caching__EntityFramework__KeyNamespace=ef
Caching__EntityFramework__DefaultExpirationSeconds=300

Caching__HttpResponse__KeyNamespace=http
Caching__HttpResponse__DefaultDurationSeconds=60
Caching__HttpResponse__CacheAuthenticatedUser=false
Caching__HttpResponse__IncludeQueryString=true
Caching__HttpResponse__VaryByHeaders__0=Accept-Language

PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOKI_PORT=3100
JAEGER_UI_PORT=16686
OTEL_COLLECTOR_GRPC_PORT=4317
OTEL_COLLECTOR_HTTP_PORT=4318
OTEL_COLLECTOR_METRICS_PORT=8889
OTLP_ENDPOINT=http://otel-collector:4317
LOKI_ENDPOINT=http://loki:3100

# ── Frontend / Nginx ──────────────────────────────────────────────────────────
# Ports exposed by the nginx container on the host
FRONTEND_HTTP_PORT=80
FRONTEND_HTTPS_PORT=443

# Domain used in the generated TLS certificate (run scripts/gen-root-ca.sh)
DOMAIN=usm.inventory.local

# ── API Gateway ───────────────────────────────────────────────────────────────
API_GATEWAY_PORT=5000
